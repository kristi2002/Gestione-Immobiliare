{
    "name": "gestione-immobiliare/app",
    "description": "Real estate agency management dashboard",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "stripe/stripe-php": "^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "config/env.php",
            "config/db.php",
            "config/settings.php",
            "config/mail.php",
            "config/mail_html.php",
            "config/whatsapp.php",
            "config/meta.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
