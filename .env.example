# Application
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/gestionale
FORCE_HTTPS=false
SESSION_NAME=gestionale_session
SETUP_ENABLED=true

# Security — change in production!
APP_SECRET=change-this-to-a-long-random-string-min-32-chars
CRON_SECRET=change-this-cron-secret-in-production

# Database
DB_HOST=localhost
DB_NAME=gestione_immobiliare
DB_USER=root
DB_PASS=root
DB_CHARSET=utf8mb4

# Admin (used by setup.php to create first user)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Email (can also be configured in Impostazioni UI)
MAIL_ENABLED=false
AGENCY_NAME=Gestionale Immobiliare
AGENCY_EMAIL=admin@agenzia.it
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls

# Meta / Instagram OAuth (App Secret also configurable in Impostazioni)
META_APP_ID=
META_APP_SECRET=
META_PUBLIC_BASE_URL=

# WhatsApp via Twilio (also configurable in Impostazioni)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM= 

# Cloud backup S3-compatible (also configurable in Impostazioni)
BACKUP_CLOUD_ENABLED=false
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=eu-central-1
BACKUP_S3_KEY=
BACKUP_S3_SECRET=
