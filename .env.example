# ==========================================================================
# Gestionale Immobiliare — environment template
# Copy to .env and fill in. Every integration is OFF by default; set its
# *_ENABLED flag and credentials to activate. See docs/INTEGRATIONS.md.
# ==========================================================================

# --- Application ----------------------------------------------------------
APP_ENV=local                 # local | production  (production => webhooks fail closed)
APP_DEBUG=true                # false in production
APP_URL=http://localhost/gestionale
FORCE_HTTPS=false             # true behind TLS/Traefik in production
SESSION_NAME=gestionale_session
SETUP_ENABLED=true            # set false after the first admin is created

# --- Security -------------------------------------------------------------
APP_SECRET=change-this-to-a-long-random-string-min-32-chars
CRON_SECRET=change-this-cron-secret-in-production   # required to trigger cron over HTTP

# --- Database -------------------------------------------------------------
DB_HOST=localhost             # host or host:port (e.g. db:3306 in Docker)
DB_NAME=gestione_immobiliare
DB_USER=gestionale_app        # use a least-privilege user in production, NOT root
DB_PASS=change-me
DB_CHARSET=utf8mb4

# --- First admin (used by setup.php) -------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong

# --- Email (SMTP; homegrown sender) --------------------------------------
MAIL_ENABLED=false            # false => emails are simulated (nothing sent)
AGENCY_NAME=Gestionale Immobiliare
AGENCY_EMAIL=admin@agenzia.it
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls               # tls | ssl
# Inbound email (Mailgun route -> api/email_inbound.php). Required in production
# to accept inbound mail; without it, unsigned inbound is rejected in production.
MAILGUN_WEBHOOK_KEY=

# --- Meta / Instagram (social publishing) --------------------------------
# Dev mode until Meta App Review. Also configurable in Impostazioni.
META_APP_ID=
META_APP_SECRET=
META_PUBLIC_BASE_URL=         # public https base, required for Instagram image posts

# --- WhatsApp via Twilio --------------------------------------------------
# Sandbox until a WhatsApp Business sender is provisioned. Webhook signature is
# required in production (unsigned requests rejected without the auth token).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# --- Stripe (payments) ----------------------------------------------------
# OFF unless both keys are set. Webhook signature required in production.
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Geocoding ------------------------------------------------------------
# Nominatim + Photon work with no key. Optional Google for ROOFTOP accuracy.
GOOGLE_GEOCODING_API_KEY=

# --- Cloud backup (S3-compatible) ----------------------------------------
BACKUP_CLOUD_ENABLED=false
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=eu-central-1
BACKUP_S3_KEY=
BACKUP_S3_SECRET=
# Path to mysqldump if not on PATH (used by cron/backup_database.php)
MYSQLDUMP_PATH=

# --- Local dev only -------------------------------------------------------
# NGROK_AUTHTOKEN=            # for the optional ngrok tunnel in docker-compose
