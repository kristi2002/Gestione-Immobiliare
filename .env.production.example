# ==========================================================================
# Gestionale Immobiliare — PRODUCTION environment template (Hetzner / Coolify)
# Copy to the deployment's environment. Fill EVERY secret with real values.
# See docs/deployment/DEPLOY.md for the full runbook.
# ==========================================================================

# --- Application ----------------------------------------------------------
APP_ENV=production            # production => webhooks fail closed, errors hidden
APP_DEBUG=false
APP_URL=https://your-domain.it
FORCE_HTTPS=true              # behind Traefik/TLS
SESSION_NAME=gestionale_session
SETUP_ENABLED=false           # keep false; flip to true only for first-run setup, then back

# --- Security (generate long random values) -------------------------------
APP_SECRET=__RANDOM_64_CHARS__            # reserved for future crypto; set it anyway
CRON_SECRET=__RANDOM_64_CHARS__           # required to trigger cron over HTTP

# --- Database (least-privilege user — NOT root) ---------------------------
DB_HOST=db                    # or managed DB host
DB_NAME=gestione_immobiliare
DB_USER=gestionale_app        # created via database/create_app_user.sql
DB_PASS=__STRONG_DB_PASSWORD__
DB_CHARSET=utf8mb4

# --- First admin (only used while SETUP_ENABLED=true) ---------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=__STRONG_ADMIN_PASSWORD__

# --- Email (SMTP) ---------------------------------------------------------
MAIL_ENABLED=true
AGENCY_NAME=Orlandi Immobiliare
AGENCY_EMAIL=info@your-domain.it
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
MAILGUN_WEBHOOK_KEY=          # required if inbound email is used

# --- Integrations (leave blank to keep OFF) -------------------------------
# WhatsApp / Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# Meta / Instagram
META_APP_ID=
META_APP_SECRET=
META_PUBLIC_BASE_URL=
# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
# Geocoding (optional)
GOOGLE_GEOCODING_API_KEY=

# --- Cloud backup (recommended: enable, EU region) ------------------------
BACKUP_CLOUD_ENABLED=false
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=eu-central-1
BACKUP_S3_KEY=
BACKUP_S3_SECRET=
MYSQLDUMP_PATH=
