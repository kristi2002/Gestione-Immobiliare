# Docker local development — copy to .env.docker (or use as-is via docker-compose env_file)
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8090
FORCE_HTTPS=false
SESSION_NAME=gestionale_session
SETUP_ENABLED=true

APP_SECRET=local-dev-secret-change-in-production-32chars
CRON_SECRET=local-cron-secret

DB_HOST=db
DB_NAME=gestione_immobiliare
DB_USER=root
DB_PASS=root
DB_CHARSET=utf8mb4

ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

MAIL_ENABLED=false
AGENCY_NAME=Gestionale Immobiliare
AGENCY_EMAIL=admin@agenzia.it

# Optional — enables ROOFTOP-level geocoding (Google Cloud Geocoding API)
# GOOGLE_GEOCODING_API_KEY=
