# Gestionale Immobiliare — Apache security rules

# Upload limits (videos up to ~25 MB). Applies on mod_php hosts without an image rebuild.
<IfModule php_module>
    php_value upload_max_filesize 25M
    php_value post_max_size 26M
    php_value max_execution_time 120
    php_value max_input_time 120
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block web access to sensitive directories
    RewriteRule ^config/ - [F,L]
    RewriteRule ^database/ - [F,L]
    RewriteRule ^cron/ - [F,L]
    RewriteRule ^backups/ - [F,L]
</IfModule>

<Files ".env">
    Require all denied
</Files>

<Files ".setup_complete">
    Require all denied
</Files>
