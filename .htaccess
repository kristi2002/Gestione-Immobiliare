# Gestionale Immobiliare — Apache security rules

# Upload limits (videos up to ~25 MB). Applies on mod_php hosts without an image rebuild.
<IfModule php_module>
    php_value upload_max_filesize 25M
    php_value post_max_size 26M
    php_value max_execution_time 120
    php_value max_input_time 120
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # ── Public website (sito vetrina "Immobiliare Orlandi") ──────────────────
    # The static marketing site lives in /web-orlandi/ and is already reachable
    # at  https://<questo-dominio>/web-orlandi/ .
    # To serve it on its OWN (sub)domain instead: point that domain's DNS at this
    # server, add the domain to this service in Coolify, then replace
    # PUBLIC-DOMAIN-HERE below with it (e.g. www.immobiliareorlandi.it) and
    # UNCOMMENT the three lines. The gestionale on its own domain is unaffected.
    #   RewriteCond %{HTTP_HOST} ^(www\.)?PUBLIC-DOMAIN-HERE$ [NC]
    #   RewriteCond %{REQUEST_URI} !^/web-orlandi/
    #   RewriteRule ^(.*)$ /web-orlandi/$1 [L]

    # Block web access to sensitive directories
    RewriteRule ^config/ - [F,L]
    RewriteRule ^database/ - [F,L]
    RewriteRule ^cron/ - [F,L]
    RewriteRule ^backups/ - [F,L]
    # Raw React source (the build output is served from /app, not /frontend)
    RewriteRule ^frontend/ - [F,L]

    # React admin SPA under /app: serve the built index.html for any client-side
    # route (deep links like /app/clients, /app/properties/42). Real files
    # (/app/assets/*, /app/index.html) are served directly; /api, /uploads etc.
    # live outside /app and are untouched.
    RewriteCond %{REQUEST_URI} ^/app/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ /app/index.html [L]

    # Defense-in-depth: deny ALL direct access to the uploaded-documents tree
    # (ID scans, contracts, generated PDFs/invoices, private attachments). These
    # are personal data and must only ever be reached via the auth-checked
    # api/download_document.php / api/download_pdf.php / api/media.php streamers.
    # This duplicates uploads/documents/.htaccess so protection survives even if
    # that nested file is lost during a deploy/rsync.
    RewriteRule ^uploads/documents/ - [F,L]

    # And never serve office/archive document types from anywhere under uploads/
    # (belt-and-suspenders for uploads/properties, which is otherwise public images).
    RewriteRule ^uploads/.*\.(pdf|docx?|xlsx?|pptx?|txt|csv|zip|rar|7z|odt|ods|odp|rtf)$ - [F,L]
</IfModule>

<Files ".env">
    Require all denied
</Files>

<Files ".setup_complete">
    Require all denied
</Files>
